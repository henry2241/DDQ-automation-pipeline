{
  "system": {
    "version": "1.0.0",
    "environment": "development",
    "debug_mode": true,
    "max_processing_time_seconds": 600,
    "max_concurrent_requests": 3
  },
  "quality_thresholds": {
    "gap_detection_accuracy": 75.0,
    "compliance_coverage": 85.0,
    "depth_score_minimum": 60.0,
    "risk_score_maximum": 35.0,
    "consistency_score_minimum": 65.0
  },
  "processing_stages": {
    "gap_detection_enabled": true,
    "gap_detection_timeout": 60,
    "gap_detection_retries": 3,
    "compliance_check_enabled": true,
    "compliance_check_timeout": 60,
    "compliance_check_retries": 3,
    "depth_analysis_enabled": true,
    "depth_analysis_timeout": 90,
    "depth_analysis_retries": 3,
    "risk_assessment_enabled": true,
    "risk_assessment_timeout": 60,
    "risk_assessment_retries": 3,
    "disclaimer_insertion_enabled": true,
    "disclaimer_insertion_timeout": 30,
    "disclaimer_insertion_retries": 3
  },
  "audit_settings": {
    "log_directory": "/tmp/ddq_dev_logs",
    "retention_days": 30,
    "max_file_size_mb": 25,
    "enable_console_output": true,
    "log_level": "DEBUG",
    "enable_performance_monitoring": true,
    "track_processing_times": true,
    "track_quality_metrics": true
  },
  "compliance_settings": {
    "critical_violation_weight": 25.0,
    "high_violation_weight": 15.0,
    "medium_violation_weight": 8.0,
    "low_violation_weight": 3.0,
    "compliance_grade_a_max": 5.0,
    "compliance_grade_b_max": 15.0,
    "compliance_grade_c_max": 30.0,
    "compliance_grade_d_max": 50.0,
    "enable_auto_fix": true,
    "auto_insert_disclaimers": true,
    "max_auto_fixes_per_response": 15
  },
  "custom": {
    "regulatory_frameworks": {
      "primary": "SEC_INVESTMENT_ADVISERS_ACT",
      "secondary": ["SEC_INVESTMENT_COMPANY_ACT", "FIDUCIARY_STANDARDS"],
      "monitoring": ["CFTC_COMMODITY_POOL_OPERATORS", "FINRA_RULES"]
    },
    "firm_defaults": {
      "default_firm_type": "investment_adviser",
      "default_client_types": ["institutional"],
      "default_disclaimers_required": true
    },
    "gap_detection_tuning": {
      "interpretive_content_threshold": 0.4,
      "factual_density_minimum": 0.5,
      "source_citation_minimum": 1.0,
      "specificity_score_target": 0.6
    },
    "compliance_tuning": {
      "performance_claim_sensitivity": "medium",
      "guarantee_language_sensitivity": "high",
      "disclaimer_insertion_mode": "automatic",
      "risk_disclosure_enforcement": "standard"
    },
    "depth_analysis_tuning": {
      "minimum_word_count": 150,
      "target_word_range": [250, 600],
      "maximum_word_count": 1000,
      "component_coverage_minimum": 70.0
    },
    "risk_assessment_tuning": {
      "fiduciary_risk_weight": 1.2,
      "performance_advertising_weight": 1.1,
      "misleading_statement_weight": 1.3,
      "disclosure_adequacy_weight": 1.0
    },
    "development_features": {
      "enable_detailed_logging": true,
      "save_intermediate_results": true,
      "enable_test_mode": true,
      "mock_external_services": false,
      "verbose_error_reporting": true
    }
  },
  "metadata": {
    "version": "1.0.0",
    "last_updated": "2024-01-15T10:00:00Z",
    "environment": "development", 
    "config_schema_version": "1.0",
    "created_by": "DDQ_System_Setup",
    "description": "Development configuration for Clara DDQ Gap Compliance System with relaxed thresholds and enhanced debugging"
  }
}